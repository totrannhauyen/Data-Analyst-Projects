      <aliases enabled='yes' />
      <column caption='Accident Severity' datatype='string' name='[Accident_Severity]' role='dimension' type='nominal' />
      <column caption='PY Accidents' datatype='integer' name='[CY Accidents (copy)_1257842223915011]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='COUNT(IF &#13;&#10;YEAR([Accident Date]) = [Parameters].[Current Year (copy)_1257842222632961]&#13;&#10;THEN&#13;&#10;[Index]&#13;&#10;END)' />
      </column>
      <column caption='PY Fatal Casualties' datatype='integer' name='[CY Fatal Casualties (copy)_1257842236235786]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM(IF &#13;&#10;YEAR([Accident Date]) = [Parameters].[Current Year (copy)_1257842222632961] AND [Accident_Severity] = &quot;Fatal&quot;&#13;&#10;THEN [Number_of_Casualties]&#13;&#10;END)' />
      </column>
      <column caption='Year of Accident Data' datatype='integer' name='[Calculation_1257842221682688]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='YEAR([Accident Date])' />
      </column>
      <column caption='CY Accidents' datatype='integer' default-format='n#,##0;-#,##0' name='[Calculation_1257842222964738]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='COUNT(IF &#13;&#10;YEAR([Accident Date]) = [Parameters].[Parameter 1]&#13;&#10;THEN&#13;&#10;[Index]&#13;&#10;END)' />
      </column>
      <column caption='YoY Accidents' datatype='real' default-format='* ▲0.00%; ▼0.00%' name='[Calculation_1257842229039108]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='([Calculation_1257842222964738]-[CY Accidents (copy)_1257842223915011])/[CY Accidents (copy)_1257842223915011]' />
      </column>
      <column caption='CY Casualties' datatype='integer' name='[Calculation_1257842234597382]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM(IF &#13;&#10;YEAR([Accident Date]) = [Parameters].[Parameter 1]&#13;&#10;THEN&#13;&#10;[Number_of_Casualties]&#13;&#10;END)' />
      </column>
      <column caption='PY Casualties' datatype='integer' name='[Calculation_1257842234916871]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM(IF &#13;&#10;YEAR([Accident Date]) = [Parameters].[Current Year (copy)_1257842222632961]&#13;&#10;THEN&#13;&#10;[Number_of_Casualties]&#13;&#10;END)' />
      </column>
      <column caption='YoY Casualties' datatype='real' default-format='*▲0.00%; ▼0.00%' name='[Calculation_1257842235011080]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='([Calculation_1257842234597382] - [Calculation_1257842234916871])/[Calculation_1257842234916871]' />
      </column>
      <column caption='CY Fatal Casualties' datatype='integer' name='[Calculation_1257842235797513]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM(IF &#13;&#10;YEAR([Accident Date]) = [Parameters].[Parameter 1] AND [Accident_Severity] = &quot;Fatal&quot;&#13;&#10;THEN [Number_of_Casualties]&#13;&#10;END)' />
      </column>
      <column caption='YoY Fatal Casualties' datatype='real' default-format='*▲0.00%; ▼0.00%' name='[Calculation_1257842236366859]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='([Calculation_1257842235797513] - [CY Fatal Casualties (copy)_1257842236235786]) / [CY Fatal Casualties (copy)_1257842236235786]' />
      </column>
      <column caption='CY Serious Casualties' datatype='integer' name='[Calculation_1257842237267980]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM(IF &#13;&#10;YEAR([Accident Date]) = [Parameters].[Parameter 1] AND [Accident_Severity] = &quot;Serious&quot;&#13;&#10;THEN [Number_of_Casualties]&#13;&#10;END)' />
      </column>
      <column caption='PY Serious Casualties' datatype='integer' name='[Calculation_1257842237403149]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM(IF &#13;&#10;YEAR([Accident Date]) = [Parameters].[Current Year (copy)_1257842222632961] AND [Accident_Severity] = &quot;Serious&quot;&#13;&#10;THEN [Number_of_Casualties]&#13;&#10;END)' />
      </column>
      <column caption='YoY Serious Casualties' datatype='real' default-format='*▲0.00%; ▼0.00%' name='[Calculation_1257842237501454]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='([Calculation_1257842237267980] - [Calculation_1257842237403149]) / [Calculation_1257842237403149]' />
      </column>
      <column caption='CY Slight Casualties' datatype='integer' name='[Calculation_1257842238148623]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM(IF &#13;&#10;YEAR([Accident Date]) = [Parameters].[Parameter 1] AND [Accident_Severity] = &quot;Slight&quot;&#13;&#10;THEN [Number_of_Casualties]&#13;&#10;END)' />
      </column>
      <column caption='PY Slight Casualties' datatype='integer' name='[Calculation_1257842238472208]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM(IF &#13;&#10;YEAR([Accident Date]) = [Parameters].[Current Year (copy)_1257842222632961] AND [Accident_Severity] = &quot;Slight&quot;&#13;&#10;THEN [Number_of_Casualties]&#13;&#10;END)' />
      </column>
      <column caption='YoY Slight Casualties' datatype='real' default-format='*▲0.00%; ▼0.00%' name='[Calculation_1257842238574609]' role='measure' type='quantitative'>
